# ============================================================
# API 配置（云端强推理，如 DeepSeek / OpenAI 等）
# 复制此文件为 .env 并填入真实 key
# ============================================================
API_KEY=sk-your-api-key-here
BASE_URL=https://api.deepseek.com

# ============================================================
# 模型配置（本地 Ollama 和云端 API 共用）
# 本地: ollama run <MODEL>，代码用 ollama.chat({ model: MODEL })
# 云端: 代码用 fetch(BASE_URL, { headers: { Authorization: API_KEY } })
# ============================================================
MODEL=qwen2.5:3b