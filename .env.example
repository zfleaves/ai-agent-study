# ============================================================
# API 配置（云端强推理，如 DeepSeek / OpenAI 等）
# 复制此文件为 .env 并填入真实 key
# ============================================================
API_KEY=sk-your-api-key-here
BASE_URL=https://api.deepseek.com/v1

# ============================================================
# 模型配置
# ============================================================
# 云端 API 模型名（强推理场景：ReAct 循环、多步规划、复杂编排）
MODEL=deepseek-chat

# 本地 Ollama 模型名（简单任务：基础对话、单工具调用）
LOCAL_MODEL=qwen2.5:3b