# ============================================================
# 云端 API 配置（所有实战统一使用云端模型）
# 复制此文件为 .env 并填入真实 key
# ============================================================
API_KEY=sk-your-api-key-here
BASE_URL=https://api.deepseek.com/v1

# ============================================================
# 多模型配置（按任务分配，可按需切换对比性能）
# 后面可以配置不同模型测试性能对比
# ============================================================

# 知识提取（Step 1 知识打标）— 需要强推理，准确识别实体/关系/事实
MODEL_EXTRACTION=deepseek-chat

# 别名消歧（Step 2 别名确认）— 需要语义理解，判断实体是否同义
MODEL_DISAMBIGUATION=deepseek-chat

# 内容审核辅助（Step 3 内容确认）— Agent 辅助建议，中等推理即可
MODEL_REVIEW=deepseek-chat

# 题目生成（Step 5 知识问答）— 需要强推理，基于图谱生成多样化题目
MODEL_QA_GENERATION=deepseek-chat

# 判分（Step 5 知识问答）— 需要语义对比，判断答案正确性
MODEL_QA_SCORING=deepseek-chat

# 默认模型（兜底）
MODEL_DEFAULT=deepseek-chat

# ============================================================
# 本地 Ollama（备用，仅用于开发调试快速测试）
# ============================================================
LOCAL_MODEL=qwen2.5:3b